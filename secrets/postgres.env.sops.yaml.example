# Network Topology + Vocera Postgres credentials.
#
# This file is the *plaintext template*; the real file committed alongside it
# is `postgres.env.sops.yaml`, encrypted with sops + age per .sops.yaml.
#
# To bootstrap:
#   cp secrets/postgres.env.sops.yaml.example secrets/postgres.env.sops.yaml
#   # edit secrets/postgres.env.sops.yaml, set real passwords
#   sops --encrypt --in-place secrets/postgres.env.sops.yaml
#   git add secrets/postgres.env.sops.yaml
#   git commit -m "bootstrap encrypted postgres secrets"
#
# Decryption + writing /etc/grafana-mimir-observability/secrets/*.env happens
# at install time via:
#   sudo bash scripts/install_secrets.sh
topology:
  password: REPLACE_WITH_REAL_TOPOLOGY_POSTGRES_PASSWORD
vocera_media_qoe:
  password: REPLACE_WITH_REAL_VOCERA_MEDIA_QOE_POSTGRES_PASSWORD
vocera_rf_validation:
  password: REPLACE_WITH_REAL_VOCERA_RF_VALIDATION_POSTGRES_PASSWORD
